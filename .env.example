# ── Microsoft Graph access token ───────────────────────────────────────────
# Used by the STDIO transport (the HTTP transport reads the token per-request
# from the `Authorization: Bearer <token>` header instead).
# This must be a valid Microsoft Graph access token with the scopes each server
# needs (Mail.*, Calendars.*, Contacts.*, Files.*, Sites.*). The servers do not
# perform OAuth themselves — supply a pre-acquired token.
MICROSOFT_ACCESS_TOKEN=

# ── Transport selection ─────────────────────────────────────────────────────
# stdio (default) or http. Can also be set per-run via the --stdio / --http flag.
MCP_TRANSPORT=stdio

# ── HTTP transport options (only relevant when MCP_TRANSPORT=http) ───────────
# Port the Streamable HTTP server listens on. Override per-run with --port <n>.
PORT=3000
# Max request body size (base64 attachments / uploads can be large).
MCP_HTTP_BODY_LIMIT=50mb

# ── Logging ─────────────────────────────────────────────────────────────────
# Set to any non-empty value to emit debug-level logs (to stderr).
# MCP_DEBUG=1
