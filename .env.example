# ── Microsoft sign-in (stdio) ──────────────────────────────────────────────
# The servers sign in with your own Entra ID app (public client) and cache a
# refresh token. Set your app's Application (client) ID, then run the server's
# `login` command once (e.g. `npx -y ms-calendar-mcp login`).
MICROSOFT_CLIENT_ID=
# Tenant: common (default), organizations, consumers, or a tenant ID.
# MICROSOFT_TENANT_ID=common
# Override the token-cache directory (default ~/.config/microsoft-mcp).
# MICROSOFT_MCP_CACHE_DIR=

# ── Advanced: pre-acquired token override ──────────────────────────────────
# Supply a Microsoft Graph access token directly to bypass sign-in (stdio).
# The HTTP transport instead reads the token per-request from the
# `Authorization: Bearer <token>` header.
# MICROSOFT_ACCESS_TOKEN=

# ── Transport selection ─────────────────────────────────────────────────────
# stdio (default) or http. Can also be set per-run via the --stdio / --http flag.
MCP_TRANSPORT=stdio

# ── HTTP transport options (only relevant when MCP_TRANSPORT=http) ───────────
# Port the Streamable HTTP server listens on. Override per-run with --port <n>.
PORT=3000
# Max request body size (base64 attachments / uploads can be large).
MCP_HTTP_BODY_LIMIT=50mb

# ── Logging ─────────────────────────────────────────────────────────────────
# Set to any non-empty value to emit debug-level logs (to stderr).
# MCP_DEBUG=1
